# EcoVerse Environment Variables

# Your Gemini API Key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=""

# Firebase Admin Configuration (For backend authentication & limit checking)
# Path to your Firebase service account JSON key file (e.g. ./firebase-adminsdk.json)
# If not provided, backend operates in Local Mode (in-memory rate limit checking)
FIREBASE_SERVICE_ACCOUNT_KEY=""

# Firebase Client Configuration (For frontend web connection)
# These will be exposed dynamically via backend /api/firebase-config endpoint
FIREBASE_API_KEY=""
FIREBASE_AUTH_DOMAIN=""
FIREBASE_PROJECT_ID=""
FIREBASE_STORAGE_BUCKET=""
FIREBASE_MESSAGING_SENDER_ID=""
FIREBASE_APP_ID=""
